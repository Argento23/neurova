                340
            ],
            "onError": "continueErrorOutput"
        },
        {
            "parameters": {
                "jsCode": "// Fallback seguro: Si la IA falla, devuelve valores vacíos para no romper el Loop.\ntry {\n  const aiOutput = $input.item.json;\n  return {\n      score: aiOutput.score || 0,\n      whatsapp: aiOutput.whatsapp || '',\n      email: aiOutput.email || '',\n      wa_msg: aiOutput.wa_msg || ''\n  };\n} catch (e) {\n  return {\n      score: 0,\n      whatsapp: '',\n      email: '',\n      wa_msg: ''\n  };\n}"
            },
