        {
            "parameters": {
                "jsCode": "const data = $input.item.json;\nconst title = $('Loop').item.json.title || 'Sin nombre';\nconst phone_maps = $('Loop').item.json.phone || '';\nconst banner = $('CONFIG').item.json.banner_url;\n\n// Datos con fallback\nconst phone = data.phone || phone_maps || '5491112345678';\nconst email = data.email || 'test@ejemplo.com';\nconst score = data.score || 5;\n\n// --- CONSTRUCCIÓN DEL EMAIL VISUAL PREMIUM ---\nconst style_container = \"max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 12px; overflow: hidden; font-family: 'Segoe UI', Arial, sans-serif; box-shadow: 0 4px 20px rgba(0,0,0,0.05); border: 1px solid #f0f0f0;\";\nconst style_header = `background-image: url('${banner}'); background-size: cover; background-position: center; height: 180px; position: relative;`;\nconst style_overlay = \"position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.6) 100%);\";\nconst style_title = \"position: absolute; bottom: 20px; left: 30px; color: #ffffff; font-size: 24px; font-weight: bold; text-shadow: 0 2px 4px rgba(0,0,0,0.3); letter-spacing: 1px;\";\nconst style_body = \"padding: 40px 30px; color: #444; line-height: 1.6; font-size: 16px;\";\nconst style_footer = \"background-color: #f9fafb; padding: 20px; text-align: center; border-top: 1px solid #eee; font-size: 12px; color: #888;\";\nconst style_btn = \"display: inline-block; background-color: #2563eb; color: #ffffff; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: 600; margin-top: 20px;\";\n\nconst email_html_visual = `\n<div style=\"${style_container}\">\n    <!-- HEADER VISUAL -->\n    <div style=\"${style_header}\">\n        <div style=\"${style_overlay}\"></div>\n        <div style=\"${style_title}\">GENERARISE</div>\n    </div>\n\n    <!-- BODY CONTENT -->\n    <div style=\"${style_body}\">\n        ${data.email_body || `<p>Hola equipo de <strong>${title}</strong>,</p><p>Detectamos una oportunidad para automatizar sus procesos con IA.</p>`}\n        \n        <div style=\"text-align: center; margin-top: 30px;\">\n            <a href=\"https://generarise.space\" style=\"${style_btn}\">VER DEMOSTRACIÓN</a>\n        </div>\n    </div>\n\n    <!-- FOOTER PRO -->\n    <div style=\"${style_footer}\">\n        <p style=\"margin-bottom: 5px;\"><strong>GenerArise AI Solutions</strong></p>\n        <p style=\"margin: 0;\">Buenos Aires, Argentina • <a href=\"https://generarise.space\" style=\"color:#2563eb; text-decoration:none;\">generarise.space</a></p>\n    </div>\n</div>\n`;\n\nreturn {\n  text: title,\n  score: score,\n  email_address: email,\n  phone: phone,\n  wa_msg: data.wa_msg || `Hola equipo de ${title}, somos GenerArise. Automatizamos procesos con IA para escalar negocios. ¿Les interesa una demo? 🚀`,\n  email_html: email_html_visual,\n  search_term: $('CONFIG').item.json.search_term,\n  location: $('CONFIG').item.json.location,\n  raw_ai: JSON.stringify(data)\n};"
            },
