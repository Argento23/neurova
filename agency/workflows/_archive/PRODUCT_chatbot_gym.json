                        "index": 0
                    }
                ],
                [
                    {
                        "node": "Pregunta Horarios?",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Groq Trial": {
            "ai_languageModel": [
                [
                    {
                        "node": "Extraer Info Trial",
                        "type": "ai_languageModel",
                        "index": 0
                    }
                ]
            ]
        },
        "Extraer Info Trial": {
            "main": [
                [
                    {
                        "node": "Verificar Datos",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Verificar Datos": {
            "main": [
                [
                    {
                        "node": "Datos Completos?",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Datos Completos?": {
            "main": [
                [
                    {
