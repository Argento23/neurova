                    }
                ],
                [
                    {
                        "node": "Pedir Datos Trial",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Confirmar Trial": {
            "main": [
                [
                    {
                        "node": "Enviar WhatsApp",
                        "type": "main",
