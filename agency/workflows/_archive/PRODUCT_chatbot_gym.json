                        "index": 0
                    }
                ]
            ]
        },
        "Respuesta General": {
            "main": [
                [
                    {
                        "node": "Enviar WhatsApp",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Enviar WhatsApp": {
            "main": [
                [
                    {
                        "node": "Log Lead",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Log Lead": {
            "main": [
