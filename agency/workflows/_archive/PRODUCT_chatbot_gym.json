                    }
                ]
            ]
        },
        "Pedir Datos Trial": {
            "main": [
                [
                    {
                        "node": "Enviar WhatsApp",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Pregunta Horarios?": {
            "main": [
                [
                    {
