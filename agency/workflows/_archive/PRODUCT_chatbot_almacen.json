                        "index": 0
                    }
                ]
            ]
        },
        "Buscar Producto": {
            "main": [
                [
                    {
                        "node": "Enviar WhatsApp",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Es Pedido?": {
            "main": [
                [
                    {
                        "node": "Extraer Pedido",
                        "type": "main",
                        "index": 0
                    }
                ],
                []
            ]
        },
        "Groq Extract Order": {
            "ai_languageModel": [
                [
                    {
                        "node": "Extraer Pedido",
                        "type": "ai_languageModel",
                        "index": 0
                    }
                ]
            ]
        },
        "Extraer Pedido": {
            "main": [
                [
                    {
                        "node": "Verificar Pedido",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Verificar Pedido": {
            "main": [
                [
                    {
                        "node": "Pedido Completo?",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Pedido Completo?": {
            "main": [
                [
                    {
