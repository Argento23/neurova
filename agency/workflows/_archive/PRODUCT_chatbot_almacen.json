                    }
                ]
            ]
        },
        "Extraer Mensaje": {
            "main": [
                [
                    {
                        "node": "Consulta Producto?",
                        "type": "main",
                        "index": 0
                    },
                    {
                        "node": "CONFIG",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "CONFIG": {
            "main": [
                [
                    {
                        "node": "Respuesta General",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Consulta Producto?": {
