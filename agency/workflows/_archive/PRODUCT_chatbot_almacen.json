                        "index": 0
                    }
                ],
                [
                    {
                        "node": "Es Pedido?",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Obtener Catálogo": {
            "main": [
                [
                    {
                        "node": "Buscar Producto",
