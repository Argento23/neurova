                    }
                ],
                [
                    {
                        "node": "Pedir Faltantes",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Confirmar Pedido": {
            "main": [
                [
                    {
                        "node": "Enviar WhatsApp",
                        "type": "main",
