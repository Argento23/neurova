                    }
                ]
            ]
        },
        "Pedir Faltantes": {
            "main": [
                [
                    {
                        "node": "Enviar WhatsApp",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Groq General": {
            "ai_languageModel": [
                [
                    {
                        "node": "Respuesta General",
                        "type": "ai_languageModel",
                        "index": 0
                    }
                ]
            ]
        },
        "Respuesta General": {
            "main": [
                [
                    {
                        "node": "Enviar WhatsApp",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Enviar WhatsApp": {
            "main": [
                [
                    {
                        "node": "Log Pedido",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Log Pedido": {
            "main": [
                [
                    {
                        "node": "Response OK",
