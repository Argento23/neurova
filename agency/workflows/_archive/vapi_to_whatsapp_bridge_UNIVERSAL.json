{
    "name": "Vapi WhatsApp Bridge - UNIVERSAL",
    "nodes": [
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "vapi-whatsapp-bridge",
                "options": {},
                "responseMode": "responseNode"
            },
            "id": "webhook-id",
            "name": "VapiWebhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2,
            "position": [
                100,
                300
            ]
        },
        {
            "parameters": {
                "assignments": {
                    "assignments": [
                        {
                            "id": "phone-id",
                            "name": "phone",
                            "value": "={{ $json.body?.message?.toolCalls?.[0]?.function?.arguments?.phone || $json.body?.phone || \"5491112345678\" }}",
                            "type": "string"
                        },
                        {
                            "id": "msg-id",
                            "name": "message",
                            "value": "={{ $json.body?.message?.toolCalls?.[0]?.function?.arguments?.message || $json.body?.message || \"Hola! En breve te contacto.\" }}",
                            "type": "string"
                        },
                        {
                            "id": "call-id",
                            "name": "toolCallId",
                            "value": "={{ $json.body?.message?.toolCalls?.[0]?.id || \"test-call-id\" }}",
                            "type": "string"
                        }
                    ]
                },
                "options": {}
            },
            "id": "set-node-id",
            "name": "PrepareData",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3.2,
            "position": [
                350,
                300
            ]
        },
        {
            "parameters": {
                "resource": "messages-api",
                "instanceName": "GenerArise",
                "options_message": {
                    "number": "={{ $json.phone }}",
                    "textMessage": {
                        "text": "={{ $json.message }}"
                    }
                }
            },
            "id": "evo-id",
            "name": "Evolution API",
            "type": "n8n-nodes-evolution-api.evolutionApi",
            "typeVersion": 1,
            "position": [
                600,
                300
            ],
            "continueOnFail": true,
            "credentials": {
                "evolutionApi": {
                    "id": "bzWosesjRnlSmCBY",
                    "name": "GenerArise"
                }
            }
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "={\n  \"results\": [\n    {\n      \"toolCallId\": \"{{ $('PrepareData').item.json.toolCallId || 'no-id' }}\",\n      \"result\": \"Mensaje enviado correctamente.\"\n    }\n  ]\n}"
            },
            "id": "respond-id",
            "name": "Respond to Vapi",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1.1,
            "position": [
                850,
                300
            ]
        }
    ],
    "connections": {
        "VapiWebhook": {
            "main": [
                [
                    {
                        "node": "PrepareData",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "PrepareData": {
            "main": [
                [
                    {
                        "node": "Evolution API",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Evolution API": {
            "main": [
                [
                    {
                        "node": "Respond to Vapi",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    }
}
