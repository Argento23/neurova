            ],
            "credentials": {
                "gmailOAuth2": {
                    "id": "YOUR_GMAIL_CREDENTIAL_ID",
                    "name": "Gmail account"
                }
            }
        },
        {
            "parameters": {
                "operation": "update",
                "documentId": {
                    "__rl": true,
                    "value": "YOUR_SHEET_ID",
                    "mode": "id"
                },
                "sheetName": {
                    "__rl": true,
                    "value": "leads_outreach",
                    "mode": "list"
                },
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": {
                        "Estado": "={{ $json.follow_up_type === 'first' ? 'Follow-up 1' : 'Follow-up 2 (Final)' }}",
                        "Ultimo_Contacto": "={{ $now.format('yyyy-MM-dd HH:mm:ss') }}"
                    }
                }
            },
            "id": "update_status",
            "name": "Actualizar Estado",
