{
  "name": "ALEX_ULTRA_MASTER_V4",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-alex-hybrid-v4",
        "options": {},
        "responseMode": "responseNode"
      },
      "id": "ax-webhook-v4",
      "name": "Webhook Alex V4",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        100,
        240
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "v4-is-vapi",
              "name": "is_vapi",
              "value": "={{ ($json.body?.message?.type === 'tool-call' || $json.body?.message?.toolCalls) ? true : false }}",
              "type": "boolean"
            },
            {
              "id": "v4-phone",
              "name": "phone",
              "value": "={{ ($json.body?.message?.toolCalls?.[0]?.function?.arguments?.phone || $json.body?.data?.key?.remoteJid || $json.body?.key?.remoteJid || \"\").toString().replace(/[^0-9@s.whatsapp.net]/g, '') }}",
              "type": "string"
            },
            {
              "id": "v4-tool-id",
              "name": "toolCallId",
              "value": "={{ $json.body?.message?.toolCalls?.[0]?.id || \"no-id\" }}",
              "type": "string"
            },
            {
              "id": "v4-msg-vapi",
              "name": "msg_vapi",
              "value": "={{ ($json.body?.message?.toolCalls?.[0]?.function?.arguments?.message || \"\").toString() }}",
              "type": "string"
            },
            {
              "id": "v4-user-txt",
              "name": "user_text",
              "value": "={{ $json.body?.data?.message?.conversation || $json.body?.data?.message?.extendedTextMessage?.text || $json.body?.message?.conversation || $json.body?.message?.extendedTextMessage?.text || \"Hola\" }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "ax-set-v4",
      "name": "Normalize Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        300,
        240
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeFilter": "string"
          },
          "conditions": [
            {
              "id": "v4-cond",
              "leftValue": "={{ $json.is_vapi }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "ax-if-v4",
      "name": "Is Vapi?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        500,
        240
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"results\": [\n    {\n      \"toolCallId\": \"{{ $json.toolCallId }}\",\n      \"result\": \"SUCCESS: Alex sent the WhatsApp message.\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "ax-resp-vapi-v4",
      "name": "Respond to Vapi",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        700,
        360
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "{\"status\":\"received\"}",
        "options": {}
      },
      "id": "ax-resp-wa-v4",
      "name": "Respond to WA",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        700,
        140
      ]
    },
    {
      "parameters": {
        "model": "meta-llama/llama-3.3-70b-versatile",
        "options": {
          "temperature": 0.7
        }
      },
      "id": "ax-groq-v4",
      "name": "Groq Alex",
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        900,
        0
      ],
      "credentials": {
        "groqApi": {
          "id": "t7iYzRwAE19Qfzou",
          "name": "Groq account"
        }
      }
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Eres Alex, Senior SDR de GenerArise AI.\n\nIDENTIDAD: Directo, experto, ventas agresivas. No pides permiso para automatizar, pides cita para demostrarlo. Habla como un humano experto, no como un robot.\n\nUSUARIO DICE: {{ $json.user_text }}\n\nTAREA: Responde de forma muy persuasiva y conversacional. Tu objetivo es que agenden la auditoría aquí: https://cal.com/gustavo-a.-dornhofer-nqjqos/argenterio\nINSTRUCCIONES: Responde siempre saludando y explicando algo brevemente antes del link. RESPUESTA SOLO TEXTO.",
        "hasOutputParser": true
      },
      "id": "ax-ai-v4",
      "name": "AI SDR Alex",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [
        1050,
        0
      ]
    },
    {
      "parameters": {
        "resource": "messages-api",
        "instanceName": "GenerArise",
        "options_message": {
          "number": "={{ $json.phone.includes('@') ? $json.phone : $json.phone + '@s.whatsapp.net' }}",
          "textMessage": {
            "text": "={{ $node[\"AI SDR Alex\"]?.json?.text || $json.msg_vapi }}"
          }
        }
      },
      "id": "ax-evo-v4",
      "name": "Evolution Alex V4",
      "type": "n8n-nodes-base.evolutionApi",
      "typeVersion": 1,
      "position": [
        1300,
        140
      ],
      "credentials": {
        "evolutionApi": {
          "id": "bzWosesjRnlSmCBY",
          "name": "GenerArise"
        }
      }
    }
  ],
  "connections": {
    "Webhook Alex V4": {
      "main": [
        [
          {
            "node": "Normalize Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Normalize Data": {
      "main": [
        [
          {
            "node": "Is Vapi?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Is Vapi?": {
      "main": [
        [
          {
            "node": "Respond to Vapi",
            "type": "main",
            "index": 0
          },
          {
            "node": "Evolution Alex V4",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Respond to WA",
            "type": "main",
            "index": 0
          },
          {
            "node": "Groq Alex",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Groq Alex": {
      "ai_languageModel": [
        [
          {
            "node": "AI SDR Alex",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "AI SDR Alex": {
      "main": [
        [
          {
            "node": "Evolution Alex V4",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}