{
    "name": "ALEX_V6_DUAL_MASTER",
    "nodes": [
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "vapi-alex-v6",
                "options": {},
                "responseMode": "responseNode"
            },
            "id": "ax-webhook-vapi-v6",
            "name": "Webhook VAPI",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                0,
                0
            ]
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "={\n  \"results\": [\n    {\n      \"toolCallId\": \"{{ $json.body.message.toolCalls[0].id }}\",\n      \"result\": \"Message sent\"\n    }\n  ]\n}",
                "options": {}
            },
            "id": "ax-resp-vapi-v6",
            "name": "Respond to VAPI",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                240,
                -40
            ]
        },
        {
            "parameters": {
                "resource": "messages-api",
                "instanceName": "GenerArise",
                "options_message": {
                    "number": "={{ $json.body.message.toolCalls[0].function.arguments.phone.replace(/[^0-9]/g, '') + '@s.whatsapp.net' }}",
                    "textMessage": {
                        "text": "={{ $json.body.message.toolCalls[0].function.arguments.message }}"
                    }
                }
            },
            "id": "ax-evo-vapi-v6",
            "name": "Evolution VAPI",
            "type": "n8n-nodes-base.evolutionApi",
            "typeVersion": 1,
            "position": [
                480,
                0
            ],
            "credentials": {
                "evolutionApi": {
                    "id": "bzWosesjRnlSmCBY",
                    "name": "GenerArise"
                }
            }
        },
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "chat-alex-v6",
                "options": {},
                "responseMode": "responseNode"
            },
            "id": "ax-webhook-wa-v6",
            "name": "Webhook WA",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                0,
                360
            ]
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "{\"status\":\"success\"}",
                "options": {}
            },
            "id": "ax-resp-wa-v6",
            "name": "Respond to WA",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                240,
                240
            ]
        },
        {
            "parameters": {
                "assignments": {
                    "assignments": [
                        {
                            "id": "v6-wa-phone",
                            "name": "phone",
                            "value": "={{ ($json.body.data?.key?.remoteJid || $json.body.key?.remoteJid || \"\").replace(/[^0-9]/g, '') }}",
                            "type": "string"
                        },
                        {
                            "id": "v6-wa-text",
                            "name": "text",
                            "value": "={{ $json.body.data?.message?.conversation || $json.body.data?.message?.extendedTextMessage?.text || $json.body.message?.conversation || \"Me gustaría saber más\" }}",
                            "type": "string"
                        }
                    ]
                },
                "options": {}
            },
            "id": "ax-extractor-wa-v6",
            "name": "Extractor WA",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3,
            "position": [
                240,
                440
            ]
        },
        {
            "parameters": {
                "model": "meta-llama/llama-3.3-70b-versatile",
                "options": {
                    "temperature": 0.7
                }
            },
            "id": "ax-groq-wa-v6",
            "name": "Groq LLM WA",
            "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
            "typeVersion": 1,
            "position": [
                540,
                580
            ],
            "credentials": {
                "groqApi": {
                    "id": "t7iYzRwAE19Qfzou",
                    "name": "Groq account"
                }
            }
        },
        {
            "parameters": {
                "promptType": "define",
                "text": "=Eres Alex, SDR de GenerArise AI.\n\nMENSAJE DEL USUARIO: {{ $json.text }}\n\nINSTRUCCIONES CRÍTICAS:\n1. HABLA COMO UN HUMANO NORMAL. Sé breve, directo y genera empatía comercial.\n2. NO envíes agendadores inmediatamente al principio. Saluda y crea expectativa.\n3. Si el usuario acepta, pide información o muestra interés explícito, DALE ESTE ENLACE: https://cal.com/gustavo-a.-dornhofer-nqjqos/argenterio\n4. Nunca des respuestas de máquina (como 'te enviaré'). Sé persuasivo.",
                "hasOutputParser": true
            },
            "id": "ax-ai-wa-v6",
            "name": "AI Chain WA",
            "type": "@n8n/n8n-nodes-langchain.chainLlm",
            "typeVersion": 1.4,
            "position": [
                540,
                440
            ]
        },
        {
            "parameters": {
                "resource": "messages-api",
                "instanceName": "GenerArise",
                "options_message": {
                    "number": "={{ $json.phone + '@s.whatsapp.net' }}",
                    "textMessage": {
                        "text": "={{ $node[\"AI Chain WA\"].json.text }}"
                    }
                }
            },
            "id": "ax-evo-wa-v6",
            "name": "Evolution WA",
            "type": "n8n-nodes-base.evolutionApi",
            "typeVersion": 1,
            "position": [
                860,
                440
            ],
            "credentials": {
                "evolutionApi": {
                    "id": "bzWosesjRnlSmCBY",
                    "name": "GenerArise"
                }
            }
        }
    ],
    "connections": {
        "Webhook VAPI": {
            "main": [
                [
                    {
                        "node": "Respond to VAPI",
                        "type": "main",
                        "index": 0
                    },
                    {
                        "node": "Evolution VAPI",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Webhook WA": {
            "main": [
                [
                    {
                        "node": "Respond to WA",
                        "type": "main",
                        "index": 0
                    },
                    {
                        "node": "Extractor WA",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Extractor WA": {
            "main": [
                [
                    {
                        "node": "AI Chain WA",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Groq LLM WA": {
            "ai_languageModel": [
                [
                    {
                        "node": "AI Chain WA",
                        "type": "ai_languageModel",
                        "index": 0
                    }
                ]
            ]
        },
        "AI Chain WA": {
            "main": [
                [
                    {
                        "node": "Evolution WA",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    }
}