                    }
                }
            },
            "id": "evo",
            "name": "WA",
            "type": "n8n-nodes-evolution-api.evolutionApi",
            "typeVersion": 1,
            "position": [
                -1700,
                1400
            ],
            "credentials": {
                "evolutionApi": {
                    "id": "bzWosesjRnlSmCBY",
                    "name": "LATAM"
                }
            },
            "continueOnFail": true
        },
        {
            "parameters": {
                "senderEmail": "gustavo@neurova.ai",
                "toEmail": "={{ $json.email }}",
                "subject": "Propuesta Neurova AI",
                "htmlContent": "={{ $json.html }}"
            },
            "id": "brevo",
            "name": "Email",
            "type": "n8n-nodes-base.sendInBlue",
            "typeVersion": 2,
