            "name": "Web",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                -2500,
                1400
            ],
            "continueOnFail": true
        },
        {
            "parameters": {
                "jsCode": "const html = $input.item.json.data || '';\nconst text = html.replace(/<[^>]*>/g, ' ').replace(/\\s+/g, ' ');\nreturn { text: text.substring(0, 2000), title: $('Loop').item.json.title };"
            },
            "id": "clean",
            "name": "Clean",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                -2300,
                1400
            ]
        },
        {
            "parameters": {
                "model": "meta-llama/llama-3.3-70b-versatile"
            },
            "id": "groq",
            "name": "Groq",
            "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
            "typeVersion": 1,
            "position": [
                -2100,
                1600
            ],
            "credentials": {
                "groqApi": {
                    "id": "t7iYzRwAE19Qfzou",
                    "name": "Groq account"
                }
            }
        },
        {
            "parameters": {
                "promptType": "define",
                "text": "=Analiza:\n{{ $json.text }}\n\nNombre: {{ $json.title }}\n\nExtrae:\n1. Teléfono/WhatsApp (549+digits)\n2. Email\n3. Score 1-10\n4. Mensaje WA corto\n5. Email HTML profesional\n\nJSON:\n{\n  \"phone\": \"\",\n  \"email\": \"\",\n  \"score\": 0,\n  \"wa\": \"Hola...\",\n  \"html\": \"<p>Hola...</p>\"\n}",
                "hasOutputParser": true
            },
            "id": "ai",
            "name": "AI",
            "type": "@n8n/n8n-nodes-langchain.chainLlm",
            "typeVersion": 1.4,
            "position": [
                -2100,
                1400
            ],
            "continueOnFail": true
        },
        {
            "parameters": {
                "jsCode": "const d = $input.item.json;\nreturn {\n  title: $('Loop').item.json.title,\n  phone: d.phone || '',\n  email: d.email || '',\n  score: d.score || 0,\n  wa: d.wa || 'Hola, vimos su web',\n  html: d.html || '<p>Hola, nos interesa contactar</p>'\n};"
            },
            "id": "parse",
            "name": "Parse",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                -1900,
                1400
            ]
        },
        {
            "parameters": {
                "resource": "messages-api",
                "instanceName": "LATAM",
                "options_message": {
                    "number": "={{ $json.phone }}",
                    "textMessage": {
