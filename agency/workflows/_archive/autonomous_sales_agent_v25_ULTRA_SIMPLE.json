        {
            "parameters": {
                "operation": "append",
                "documentId": {
                    "__rl": true,
                    "value": "1b_nPYFDov3Rg2ljPQ6hRLwUhoSznfw5GmyneBqCNJWg",
                    "mode": "id"
                },
                "sheetName": {
                    "__rl": true,
                    "value": "Hoja 1",
                    "mode": "list"
                },
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": {
                        "Empresa": "={{ $json.title }}",
                        "Telefono": "={{ $json.phone }}",
                        "Email": "={{ $json.email }}",
                        "Score": "={{ $json.score }}",
                        "Fecha": "={{ $now.toISO() }}"
                    }
                }
            },
            "id": "sheet",
            "name": "Sheet",
            "type": "n8n-nodes-base.googleSheets",
