{
    "name": "GenerArise - Social Media Publisher (Imágenes)",
    "nodes": [
        {
            "parameters": {
                "rule": {
                    "interval": [
                        {
                            "field": "hours",
                            "hoursInterval": 3
                        }
                    ]
                }
            },
            "id": "cron",
            "name": "Cron Cada 3 Horas",
            "type": "n8n-nodes-base.cron",
            "typeVersion": 1,
            "position": [
                240,
                400
            ]
        },
        {
            "parameters": {},
            "id": "manual",
            "name": "Manual Trigger",
            "type": "n8n-nodes-base.manualTrigger",
            "typeVersion": 1,
            "position": [
                240,
                600
            ]
        },
        {
            "parameters": {
                "operation": "read",
                "documentId": {
                    "__rl": true,
                    "value": "YOUR_SHEET_ID",
                    "mode": "id"
                },
                "sheetName": {
                    "__rl": true,
                    "value": "content_calendar",
                    "mode": "list"
                }
            },
            "id": "read_calendar",
            "name": "Leer Calendario",
            "type": "n8n-nodes-base.googleSheets",
            "typeVersion": 4.5,
            "position": [
                460,
                400
            ],
            "credentials": {
                "googleSheetsOAuth2Api": {
                    "id": "YOUR_GOOGLE_CREDENTIAL_ID",
                    "name": "Google Sheets account"
                }
            }
        },
        {
            "parameters": {
                "conditions": {
                    "options": {},
                    "conditions": [
                        {
                            "leftValue": "={{ $json.Estado }}",
                            "rightValue": "Listo",
                            "operator": {
                                "type": "string",
                                "operation": "equals"
                            }
                        },
                        {
                            "leftValue": "={{ $json['Tipo Post'] }}",
                            "rightValue": "Video",
                            "operator": {
                                "type": "string",
                                "operation": "notContains"
                            }
                        },
                        {
                            "leftValue": "={{ new Date($json.Fecha + ' ' + $json['Hora Publicación']).getTime() }}",
                            "rightValue": "={{ $now.toMillis() }}",
                            "operator": {
                                "type": "number",
                                "operation": "lte"
                            }
                        }
                    ]
                }
            },
            "id": "filter_ready",
            "name": "Filtrar Posts Listos (Solo Imágenes)",
            "type": "n8n-nodes-base.filter",
            "typeVersion": 2,
            "position": [
                680,
                400
            ]
        },
        {
            "parameters": {
                "assignments": {
                    "assignments": [
                        {
                            "id": "caption_full",
                            "name": "caption_full",
                            "value": "={{ $json.Caption + '\\n\\n' + $json.Hashtags }}",
                            "type": "string"
                        },
                        {
                            "id": "image_url",
                            "name": "image_url",
                            "value": "={{ $json.Imagen_URL }}",
                            "type": "string"
                        },
                        {
                            "id": "redes",
                            "name": "redes",
                            "value": "={{ $json['Red Social'].split('|') }}",
                            "type": "array"
                        }
                    ]
                }
            },
            "id": "prep_data",
            "name": "Preparar Data",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3,
            "position": [
                900,
                400
            ]
        },
        {
            "parameters": {
                "fieldToSplitOut": "redes",
                "options": {}
            },
            "id": "split_networks",
            "name": "Dividir por Red",
            "type": "n8n-nodes-base.itemLists",
            "typeVersion": 3,
            "position": [
                1120,
                400
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {},
                    "conditions": [
                        {
                            "leftValue": "={{ $json.redes }}",
                            "rightValue": "Instagram",
                            "operator": {
                                "type": "string",
                                "operation": "equals"
                            }
                        }
                    ]
                }
            },
            "id": "is_instagram",
            "name": "Es Instagram?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                1340,
                250
            ]
        },
        {
            "parameters": {
                "url": "https://graph.facebook.com/v19.0/YOUR_IG_USER_ID/media",
                "authentication": "genericCredentialType",
                "genericAuthType": "oAuth2Api",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"image_url\": \"{{ $('Preparar Data').item.json.image_url }}\",\n  \"caption\": \"{{ $('Preparar Data').item.json.caption_full }}\",\n  \"access_token\": \"YOUR_META_ACCESS_TOKEN\"\n}",
                "options": {}
            },
            "id": "post_instagram",
            "name": "Publicar Instagram",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                1560,
                150
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {},
                    "conditions": [
                        {
                            "leftValue": "={{ $json.redes }}",
                            "rightValue": "Facebook",
                            "operator": {
                                "type": "string",
                                "operation": "equals"
                            }
                        }
                    ]
                }
            },
            "id": "is_facebook",
            "name": "Es Facebook?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                1340,
                400
            ]
        },
        {
            "parameters": {
                "url": "https://graph.facebook.com/v19.0/YOUR_PAGE_ID/photos",
                "authentication": "genericCredentialType",
                "genericAuthType": "oAuth2Api",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"url\": \"{{ $('Preparar Data').item.json.image_url }}\",\n  \"caption\": \"{{ $('Preparar Data').item.json.caption_full }}\",\n  \"access_token\": \"YOUR_META_ACCESS_TOKEN\"\n}",
                "options": {}
            },
            "id": "post_facebook",
            "name": "Publicar Facebook",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
