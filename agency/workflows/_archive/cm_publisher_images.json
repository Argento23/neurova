        {
            "parameters": {
                "conditions": {
                    "options": {},
                    "conditions": [
                        {
                            "leftValue": "={{ $json.redes }}",
                            "rightValue": "LinkedIn",
                            "operator": {
                                "type": "string",
                                "operation": "equals"
                            }
                        }
                    ]
                }
            },
            "id": "is_linkedin",
            "name": "Es LinkedIn?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                1340,
                550
            ]
        },
        {
            "parameters": {
                "url": "https://api.linkedin.com/v2/ugcPosts",
                "authentication": "genericCredentialType",
                "genericAuthType": "oAuth2Api",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "X-Restli-Protocol-Version",
                            "value": "2.0.0"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"author\": \"urn:li:organization:YOUR_COMPANY_ID\",\n  \"lifecycleState\": \"PUBLISHED\",\n  \"specificContent\": {\n    \"com.linkedin.ugc.ShareContent\": {\n      \"shareCommentary\": {\n        \"text\": \"{{ $('Preparar Data').item.json.caption_full }}\"\n      },\n      \"shareMediaCategory\": \"IMAGE\",\n      \"media\": [\n        {\n          \"status\": \"READY\",\n          \"media\": \"{{ $('Preparar Data').item.json.image_url }}\"\n        }\n      ]\n    }\n  },\n  \"visibility\": {\n    \"com.linkedin.ugc.MemberNetworkVisibility\": \"PUBLIC\"\n  }\n}",
                "options": {}
            },
            "id": "post_linkedin",
            "name": "Publicar LinkedIn",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                1560,
                450
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {},
                    "conditions": [
                        {
                            "leftValue": "={{ $json.redes }}",
                            "rightValue": "X",
                            "operator": {
                                "type": "string",
                                "operation": "contains"
                            }
                        }
                    ]
                }
            },
            "id": "is_x",
            "name": "Es X/Twitter?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                1340,
                700
            ]
        },
        {
            "parameters": {
                "jsCode": "// PLACEHOLDER: Implementar con Phantom Buster o Playwright\nconsole.log('Post X/Twitter:', $('Preparar Data').item.json.caption_full);\n\nreturn {\n  status: 'pending',\n  message: 'Implementar API X alternativa',\n  caption: $('Preparar Data').item.json.caption_full\n};"
            },
            "id": "post_x",
            "name": "Publicar X (Pendiente)",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1560,
                600
            ]
        },
        {
            "parameters": {
                "operation": "update",
                "documentId": {
                    "__rl": true,
                    "value": "YOUR_SHEET_ID",
                    "mode": "id"
                },
                "sheetName": {
                    "__rl": true,
                    "value": "content_calendar",
                    "mode": "list"
                },
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": {
                        "Estado": "Publicado",
                        "Fecha_Publicacion": "={{ $now.format('yyyy-MM-dd HH:mm:ss') }}"
                    }
                }
            },
            "id": "update_status",
            "name": "Marcar como Publicado",
            "type": "n8n-nodes-base.googleSheets",
            "typeVersion": 4.5,
            "position": [
                1780,
                400
            ],
            "credentials": {
                "googleSheetsOAuth2Api": {
                    "id": "YOUR_GOOGLE_CREDENTIAL_ID",
                    "name": "Google Sheets account"
                }
            }
        }
