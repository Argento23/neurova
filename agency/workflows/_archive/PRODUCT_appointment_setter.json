                "path": "new-lead",
                "responseMode": "responseNode",
                "options": {}
            },
            "id": "webhook_lead",
            "name": "Webhook: Nuevo Lead",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2,
            "position": [
                240,
                400
            ],
            "notes": "Recibe leads de: Phantombuster, Apollo, formularios web, etc."
        },
        {
            "parameters": {
                "assignments": {
                    "assignments": [
                        {
                            "id": "nombre",
