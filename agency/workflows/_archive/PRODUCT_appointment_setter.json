            "id": "extract_lead",
            "name": "Extraer Info Lead",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3,
            "position": [
                460,
                400
            ]
        },
        {
            "parameters": {
                "assignments": {
                    "assignments": [
                        {
                            "id": "cliente_nombre",
                            "name": "cliente_nombre",
                            "value": "NOMBRE_CLIENTE",
                            "type": "string"
                        },
                        {
                            "id": "servicio",
                            "name": "servicio",
                            "value": "Marketing Digital / Google Ads / Meta Ads",
                            "type": "string"
                        },
                        {
                            "id": "icp_criteria",
                            "name": "icp_criteria",
                            "value": "- Empresa 10-100 empleados\n- Industria: ecommerce, retail, servicios\n- Presupuesto ads: $50K+/mes\n- Ya usan ads (buscan mejor agencia)",
                            "type": "string"
                        },
                        {
                            "id": "calendly_link",
                            "name": "calendly_link",
                            "value": "https://calendly.com/cliente/reunion-30min",
                            "type": "string"
                        },
                        {
                            "id": "email_cliente",
                            "name": "email_cliente",
                            "value": "ventas@cliente.com",
                            "type": "string"
                        }
                    ]
                }
            },
            "id": "config",
            "name": "CONFIG Cliente",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3,
            "position": [
                680,
                600
            ]
        },
        {
            "parameters": {
                "model": "meta-llama/llama-3.3-70b-versatile"
            },
            "id": "groq_qualify",
            "name": "Groq AI Qualification",
            "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
            "typeVersion": 1,
            "position": [
                680,
                420
            ],
            "credentials": {
                "groqApi": {
                    "id": "YOUR_GROQ_CREDENTIAL_ID",
                    "name": "Groq account"
                }
            }
        },
        {
            "parameters": {
                "promptType": "define",
                "text": "=Eres un SDR experto calificando leads B2B.\n\nCRITERIOS ICP (Ideal Customer Profile):\n{{ $('CONFIG Cliente').item.json.icp_criteria }}\n\nLEAD A CALIFICAR:\n- Nombre: {{ $('Extraer Info Lead').item.json.nombre }}\n- Empresa: {{ $('Extraer Info Lead').item.json.empresa }}\n- Cargo: {{ $('Extraer Info Lead').item.json.cargo }}\n- Industria: {{ $('Extraer Info Lead').item.json.industria }}\n- LinkedIn: {{ $('Extraer Info Lead').item.json.linkedin }}\n\nCALIFICA el lead con scoring BANT:\n- Budget (presupuesto aparente): 1-10\n- Authority (nivel decisión): 1-10\n- Need (encaja con ICP): 1-10\n- Timeline (urgencia): 1-10\n\nResponde JSON:\n{\n  \"budget_score\": 1-10,\n  \"authority_score\": 1-10,\n  \"need_score\": 1-10,\n  \"timeline_score\": 1-10,\n  \"total_score\": suma/4,\n  \"tier\": \"A\" (8-10) | \"B\" (6-7.9) | \"C\" (<6),\n  \"reasoning\": \"breve justificación\"\n}\n\nSolo JSON:",
                "hasOutputParser": true
            },
            "id": "qualify_lead",
            "name": "Calificar Lead (BANT)",
            "type": "@n8n/n8n-nodes-langchain.chainLlm",
            "typeVersion": 1.4,
            "position": [
                900,
                400
            ]
        },
        {
            "parameters": {
                "jsCode": "const scoring = JSON.parse($input.item.json.output);\nconst lead = $('Extraer Info Lead').item.json;\n\nreturn [{\n  json: {\n    ...lead,\n    ...scoring,\n    qualified: scoring.tier === 'A' || scoring.tier === 'B'\n  }\n}];"
            },
            "id": "process_score",
            "name": "Procesar Score",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1120,
                400
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {},
                    "conditions": [
                        {
                            "leftValue": "={{ $json.qualified }}",
                            "rightValue": "true",
                            "operator": {
                                "type": "boolean",
                                "operation": "equals"
                            }
                        }
                    ]
                }
            },
            "id": "is_qualified",
            "name": "Lead Calificado?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                1340,
                300
            ]
        },
        {
            "parameters": {
                "fromEmail": "{{ $('CONFIG Cliente').item.json.email_cliente }}",
                "toEmail": "={{ $('Extraer Info Lead').item.json.email }}",
                "subject": "=Hola {{ $('Extraer Info Lead').item.json.nombre }}, agendemos una llamada",
                "emailType": "html",
                "message": "=<html>\n<body style=\"font-family: Arial; max-width: 600px; margin: 0 auto;\">\n  <h2>Hola {{ $('Extraer Info Lead').item.json.nombre }},</h2>\n  \n  <p>Vi tu perfil y creo que {{ $('CONFIG Cliente').item.json.cliente_nombre }} puede ayudarte con {{ $('CONFIG Cliente').item.json.servicio }}.</p>\n  \n  <p>¿Tenés 30 minutos esta semana para una llamada sobre cómo optimizar tus campañas?</p>\n  \n  <div style=\"margin: 30px 0; text-align: center;\">\n    <a href=\"{{ $('CONFIG Cliente').item.json.calendly_link }}\" \n       style=\"background: #667eea; color: white; padding: 15px 30px; \n              text-decoration: none; border-radius: 8px; font-weight: bold;\">\n      📅 Agendar Reunión (30 min)\n    </a>\n  </div>\n  \n  <p>Sin compromiso, solo para ver si podemos ayudarte.</p>\n  \n  <p>Saludos,<br>\n  Equipo {{ $('CONFIG Cliente').item.json.cliente_nombre }}</p>\n</body>\n</html>",
                "options": {}
            },
            "id": "send_calendly_email",
            "name": "Enviar Email con Calendly",
            "type": "n8n-nodes-base.gmail",
            "typeVersion": 2.1,
            "position": [
                1560,
                200
            ],
            "credentials": {
                "gmailOAuth2": {
                    "id": "YOUR_GMAIL_CREDENTIAL_ID",
                    "name": "Gmail account"
                }
            }
        },
        {
            "parameters": {
                "operation": "append",
                "documentId": {
                    "__rl": true,
                    "value": "YOUR_CRM_SHEET_ID",
                    "mode": "id"
                },
                "sheetName": {
                    "__rl": true,
                    "value": "leads_pipeline",
                    "mode": "list"
                },
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": {
                        "Fecha": "={{ $now.format('yyyy-MM-dd HH:mm:ss') }}",
                        "Nombre": "={{ $json.nombre }}",
                        "Empresa": "={{ $json.empresa }}",
                        "Email": "={{ $json.email }}",
                        "Cargo": "={{ $json.cargo }}",
                        "Score_Total": "={{ $json.total_score }}",
                        "Tier": "={{ $json.tier }}",
                        "Estado": "={{ $json.qualified ? 'Email Enviado' : 'No Calificado' }}",
                        "Reasoning": "={{ $json.reasoning }}"
                    }
                }
            },
            "id": "log_crm",
            "name": "Log en CRM",
            "type": "n8n-nodes-base.googleSheets",
            "typeVersion": 4.5,
            "position": [
                1780,
                400
            ],
            "credentials": {
                "googleSheetsOAuth2Api": {
                    "id": "YOUR_GOOGLE_CREDENTIAL_ID",
                    "name": "Google Sheets account"
                }
            }
        },
        {
            "parameters": {
                "assignments": {
                    "assignments": [
                        {
                            "id": "message",
                            "name": "message",
                            "value": "=Lead {{ $json.tier }} no alcanzó threshold. Agregado a nurturing campaign.",
                            "type": "string"
                        }
                    ]
                }
            },
            "id": "nurture_low_score",
            "name": "A Nurturing Campaign",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3,
            "position": [
                1560,
                400
            ],
            "notes": "Leads C van a secuencia de emails educativos"
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "={\"success\": true, \"lead_tier\": \"{{ $json.tier }}\", \"qualified\": \"{{ $json.qualified }}\"}",
                "options": {}
            },
            "id": "response",
            "name": "Response OK",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                2000,
                400
            ]
        },
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "calendly-booked",
                "responseMode": "responseNode",
                "options": {}
            },
            "id": "webhook_booking",
            "name": "Webhook: Calendly Booked",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2,
            "position": [
                240,
                800
            ],
            "notes": "Calendly webhook cuando lead agenda reunión"
        },
        {
            "parameters": {
                "assignments": {
                    "assignments": [
                        {
                            "id": "invitee_name",
                            "name": "invitee_name",
                            "value": "={{ $json.body.payload.invitee.name }}",
                            "type": "string"
                        },
                        {
                            "id": "invitee_email",
                            "name": "invitee_email",
                            "value": "={{ $json.body.payload.invitee.email }}",
                            "type": "string"
                        },
                        {
                            "id": "event_time",
                            "name": "event_time",
                            "value": "={{ $json.body.payload.event.start_time }}",
                            "type": "string"
                        },
                        {
                            "id": "event_uri",
                            "name": "event_uri",
                            "value": "={{ $json.body.payload.event.uri }}",
