                            "value": "={{ $json.body.linkedin_url || '' }}",
                            "type": "string"
                        },
                        {
                            "id": "industria",
                            "name": "industria",
                            "value": "={{ $json.body.industria || $json.body.industry || '' }}",
                            "type": "string"
