                }
            },
            "id": "extract_booking",
            "name": "Extraer Info Booking",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3,
            "position": [
                460,
                800
            ]
        },
        {
            "parameters": {
                "operation": "update",
                "documentId": {
                    "__rl": true,
                    "value": "YOUR_CRM_SHEET_ID",
                    "mode": "id"
                },
                "sheetName": {
                    "__rl": true,
                    "value": "leads_pipeline",
                    "mode": "list"
                },
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": {
                        "Estado": "Reunión Agendada",
                        "Fecha_Reunion": "={{ $json.event_time }}",
                        "Calendly_URI": "={{ $json.event_uri }}"
                    }
                },
                "options": {
                    "lookupColumn": "Email",
                    "lookupValue": "={{ $json.invitee_email }}"
                }
            },
            "id": "update_crm_booked",
            "name": "Actualizar CRM (Agendado)",
            "type": "n8n-nodes-base.googleSheets",
            "typeVersion": 4.5,
            "position": [
                680,
                800
            ]
        },
        {
            "parameters": {
                "fromEmail": "{{ $('CONFIG Cliente').item.json.email_cliente }}",
                "toEmail": "={{ $('CONFIG Cliente').item.json.email_cliente }}",
                "subject": "=🎉 Nueva reunión agendada: {{ $json.invitee_name }}",
                "emailType": "html",
                "message": "=<html>\n<body style=\"font-family: Arial;\">\n  <h2>✅ Nuevo Lead Agendó Reunión</h2>\n  \n  <p><strong>Nombre:</strong> {{ $json.invitee_name }}</p>\n  <p><strong>Email:</strong> {{ $json.invitee_email }}</p>\n  <p><strong>Fecha/Hora:</strong> {{ $json.event_time }}</p>\n  \n  <p><strong>Próximos pasos:</strong></p>\n  <ul>\n    <li>Revisar LinkedIn del lead</li>\n    <li>Preparar preguntas de discovery</li>\n    <li>Reminder automático enviado al lead</li>\n  </ul>\n  \n  <p><a href=\"{{ $json.event_uri }}\">Ver en Calendly</a></p>\n</body>\n</html>",
                "options": {}
            },
            "id": "notify_client",
            "name": "Notificar Cliente",
            "type": "n8n-nodes-base.gmail",
            "typeVersion": 2.1,
            "position": [
                900,
                800
            ]
        },
        {
            "parameters": {
                "rule": {
                    "interval": [
                        {
                            "field": "cronExpression",
                            "expression": "0 9 * * *"
                        }
                    ]
                }
            },
            "id": "cron_reminders",
            "name": "Cron: Reminders Diarios",
            "type": "n8n-nodes-base.scheduleTrigger",
            "typeVersion": 1.2,
            "position": [
                240,
                1200
            ],
            "notes": "Chequea reuniones hoy y mañana para enviar reminders"
        },
        {
            "parameters": {
                "operation": "getAll",
                "documentId": {
                    "__rl": true,
                    "value": "YOUR_CRM_SHEET_ID",
                    "mode": "id"
                },
                "sheetName": {
                    "__rl": true,
                    "value": "leads_pipeline",
                    "mode": "list"
                },
                "options": {
                    "filter": "Estado = 'Reunión Agendada'"
                }
            },
            "id": "get_scheduled",
            "name": "Obtener Reuniones Agendadas",
            "type": "n8n-nodes-base.googleSheets",
            "typeVersion": 4.5,
            "position": [
                460,
                1200
            ]
        },
        {
            "parameters": {
                "jsCode": "const now = new Date();\nconst tomorrow = new Date(now);\ntomorrow.setDate(tomorrow.getDate() + 1);\n\nconst items = $input.all();\nconst needsReminder = [];\n\nfor (const item of items) {\n  const meetingDate = new Date(item.json.Fecha_Reunion);\n  const hoursDiff = (meetingDate - now) / (1000 * 60 * 60);\n  \n  // Reminder 24hs antes\n  if (hoursDiff > 23 && hoursDiff < 25) {\n    needsReminder.push({\n      ...item.json,\n      reminder_type: '24hs'\n    });\n  }\n  \n  // Reminder 1 hora antes\n  if (hoursDiff > 0.9 && hoursDiff < 1.1) {\n    needsReminder.push({\n      ...item.json,\n      reminder_type: '1hora'\n    });\n  }\n}\n\nreturn needsReminder.map(item => ({ json: item }));"
            },
            "id": "check_reminders",
            "name": "Filtrar Reuniones con Reminder",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                680,
                1200
            ]
        },
        {
            "parameters": {
                "fromEmail": "{{ $('CONFIG Cliente').item.json.email_cliente }}",
                "toEmail": "={{ $json.Email }}",
                "subject": "=Recordatorio: Reunión {{ $json.reminder_type === '24hs' ? 'mañana' : 'en 1 hora' }}",
                "emailType": "html",
                "message": "=<html>\n<body style=\"font-family: Arial;\">\n  <h2>👋 Hola {{ $json.Nombre }},</h2>\n  \n  <p>Te recordamos tu reunión con {{ $('CONFIG Cliente').item.json.cliente_nombre }}:</p>\n  \n  <div style=\"background: #f0f0f0; padding: 20px; border-radius: 8px; margin: 20px 0;\">\n    <p><strong>📅 Fecha:</strong> {{ $json.Fecha_Reunion }}</p>\n    <p><strong>⏰ Duración:</strong> 30 minutos</p>\n  </div>\n  \n  <p>Te esperamos!</p>\n  \n  <p>Si necesitás reprogramar: <a href=\"{{ $json.Calendly_URI }}\">click aquí</a></p>\n</body>\n</html>",
                "options": {}
            },
            "id": "send_reminder",
            "name": "Enviar Reminder",
            "type": "n8n-nodes-base.gmail",
            "typeVersion": 2.1,
            "position": [
                900,
                1200
            ]
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "={\"reminders_sent\": {{ $input.all().length }}}",
                "options": {}
            },
            "id": "response_cron",
            "name": "Response Cron",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                1120,
                1200
            ]
        }
    ],
