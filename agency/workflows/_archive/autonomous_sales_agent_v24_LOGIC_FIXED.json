        },
        {
            "parameters": {
                "jsCode": "try {\n  const aiOutput = $input.item.json;\n  return {\n      score: aiOutput.score || 0,\n      whatsapp: aiOutput.whatsapp || '',\n      email: aiOutput.email || '',\n      wa_msg: aiOutput.wa_msg || '',\n      email_html: aiOutput.email_html || '<p>Hola, vimos su web y queremos contactar.</p>'\n  };\n} catch (e) {\n  return { score: 0, whatsapp: '', email: '', wa_msg: '', email_html: '' };\n}"
            },
