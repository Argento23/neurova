        {
            "parameters": {
                "jsCode": "// SIMULACIÓN DE RESPUESTA AI (Solo para pruebas)\n// En producción, esto vendría de tu nodo AI Agent o HTTP Request\n\nreturn [\n  {\n    json: {\n      // Caso 1: Solo voz\n      // response: '{\"respuesta_voz\": \"Hola, ¿en qué puedo ayudarte?\", \"accion_requerida\": \"info\"}'\n      \n      // Caso 2: Agendar cita\n      response: '{\"respuesta_voz\": \"Perfecto, te envío mi calendario.\", \"accion_requerida\": \"agendar\"}'\n    }\n  }\n];"
            },
            "id": "mock-ai-response",
            "name": "MOCK AI (Eliminar)",
            "type": "n8n-nodes-base.code",
            "typeVersion": 1,
            "position": [
                400,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// ═══════════════════════════════════════════════════════════════\n// FILTRO SEPARADOR VOZ + ACCIÓN - ARGENTERÍO AUSTRIA (Simple)\n// El AI solo genera voz, el flujo maneja los textos automáticamente\n// ═══════════════════════════════════════════════════════════════\n\n// A. OBTENER INPUT\nlet inputData = $input.item.json.original_voice \n             || $input.item.json.text \n             || $input.item.json.output \n             || $input.item.json.response\n             || \"\";\n\n// Variables por defecto\nlet textoVoz = \"\";\nlet accionFinal = \"info\";\n\n// B. PARSEO DE RESPUESTA AI\nif (typeof inputData === 'object' && inputData !== null) {\n  // CASO 1: Ya es objeto JSON parseado\n  textoVoz = inputData.respuesta_voz || \"\";\n  accionFinal = inputData.accion_requerida || \"info\";\n\n} else if (typeof inputData === 'string') {\n  // CASO 2: Es string, intentar parsear JSON\n  \n  let cleanString = inputData\n    .replace(/```json\\s*/g, \"\")\n    .replace(/```\\s*/g, \"\")\n    .trim();\n\n  try {\n    const parsed = JSON.parse(cleanString);\n    textoVoz = parsed.respuesta_voz || \"\";\n    accionFinal = parsed.accion_requerida || \"info\";\n  } catch (e) {\n    // Fallback: Si no es JSON válido, usar como texto de voz directo\n    console.log(\"⚠️ JSON inválido, usando texto directo como voz\");\n    textoVoz = cleanString;\n    accionFinal = \"info\";\n  }\n}\n\n// C. LIMPIEZA PARA TTS (elimina símbolos que el TTS no debe leer)\nfunction cleanForTTS(text) {\n  if (!text || typeof text !== 'string') return \"\";\n  return text\n    // Remover emojis\n    .replace(/[\\u{1F600}-\\u{1F64F}\\u{1F300}-\\u{1F5FF}\\u{1F680}-\\u{1F6FF}\\u{2600}-\\u{26FF}\\u{2700}-\\u{27BF}]/gu, \"\")\n    // URLs completas eliminadas (el AI no debería decirlas)\n    .replace(/(https?:\\/\\/[^\\s]+)/g, \"\")\n    // Símbolos JSON/Markdown residuales\n    .replace(/[\"*{}\\[\\]_`]/g, \"\")\n    // Múltiples espacios → uno solo\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\n// E. RETORNO FINAL\nreturn {\n  json: {\n    clean_voice: cleanForTTS(textoVoz),              // → Va al TTS\n    accion: accionFinal.toLowerCase().trim()         // → Va al Switch\n  }\n};"
            },
            "id": "filtro-js",
            "name": "Filtro JS (Voz+Acción)",
            "type": "n8n-nodes-base.code",
            "typeVersion": 1,
            "position": [
