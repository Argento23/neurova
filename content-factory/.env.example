# ============================================
# GENERARISE CONTENT FACTORY — Configuration
# ============================================
# Copy this file to .env and fill in your values

# === AI GENERATION APIs ===
GROQ_API_KEY=gsk_your_groq_key_here
TOGETHER_API_KEY=your_together_ai_key_here

# === INSTAGRAM (Meta Graph API) ===
IG_ACCESS_TOKEN=your_instagram_long_lived_token
IG_USER_ID=17841480081723095

# === TIKTOK (Content Posting API) ===
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# === YOUTUBE (Data API v3) ===
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# === IMAGE HOSTING (ImgBB — free) ===
IMGBB_API_KEY=

# === NOTIFICATIONS (Telegram) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === BRANDING ===
BRAND_NAME=GenerArise
BRAND_URL=https://generarise.space
BRAND_TAGLINE=Automatización Inteligente con IA
BRAND_TAGLINE_EN=Intelligent Automation with AI

# === SYSTEM ===
TIMEZONE=America/Argentina/Buenos_Aires
DASHBOARD_PORT=4000
LOG_LEVEL=info
NODE_ENV=production

# ============================================
# SALES SYNERGY ENGINE — Configuration
# ============================================

# === SUPABASE (Leads Database) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key

# === LEAD DISCOVERY ===
# Option A: Google Maps Places API (recommended)
GOOGLE_MAPS_API_KEY=
# Option B: SerpAPI (alternative)
SERPAPI_KEY=

# === WHATSAPP — Meta Cloud API (RECOMMENDED — no bans, free tier) ===
# Get these from: developers.facebook.com → WhatsApp → API Setup
META_CLOUD_TOKEN=your_permanent_system_user_token
META_PHONE_NUMBER_ID=1104497082748018
META_WABA_ID=1693809771798071
# META_API_VERSION=v25.0  # Optional, defaults to v25.0

# === WHATSAPP — Evolution API (LEGACY — only if Cloud API not available) ===
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE=neurova

# === EMAIL OUTREACH ===
BREVO_API_KEY=
EMAIL_FROM=gustavo@generarise.space

# === PEXELS (Video backgrounds) ===
PEXELS_API_KEY=
