            "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
            "typeVersion": 1,
            "position": [
                1250,
                620
            ],
            "credentials": {
                "groqApi": {
                    "id": "t7iYzRwAE19Qfzou",
                    "name": "Groq account"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "return $input.all().map(item => {\n  const text = item.json.text || '';\n  let cleanJson = text;\n  const firstBrace = cleanJson.indexOf('{');\n  const lastBrace = cleanJson.lastIndexOf('}');\n  if (firstBrace !== -1 && lastBrace !== -1) {\n    cleanJson = cleanJson.substring(firstBrace, lastBrace + 1);\n  }\n  const fallback = { phone: '', email: '', wa_msg: 'Error JSON', email_body: '', email_subject: '', telegram_alert: 'Error JSON' };\n  try {\n    const parsed = JSON.parse(cleanJson);\n    let result = parsed;\n    if (parsed && typeof parsed === 'object') {\n      if (parsed.__structured__output && parsed.__structured__output.__structured__output__object) {\n        result = parsed.__structured__output.__structured__output__object;\n      }\n    }\n    if (typeof result !== 'object' || result === null || Array.isArray(result)) {\n      result = fallback;\n    }\n    return { json: { ...item.json, ...result } };\n  } catch(e) {\n    return { json: { ...item.json, ...fallback } };\n  }\n});"
            },
            "id": "parse-logic",
            "name": "Parse JSON Seguro",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1950,
                400
            ]
